# Resend — transactional email for lead notifications (optional in dev; logs to console)
RESEND_API_KEY=
LEAD_EMAIL_TO=leads@stratum.systems
LEAD_EMAIL_FROM=no-reply@stratum.systems

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
